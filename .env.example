# =============================================================================
# CalorieTracker v3 — Environment Variables
# Copy this file to .env and fill in the values.
# .env is gitignored and must never be committed.
# =============================================================================

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Individual vars used by the postgres:16 Docker image to initialise the DB
POSTGRES_USER=calorietracker
POSTGRES_PASSWORD=secret
POSTGRES_DB=calorietracker

# ── API ───────────────────────────────────────────────────────────────────────
# Full async DSN — the host "db" resolves to the Docker Compose db service.
# Replace with localhost:5432 when running the API outside Docker.
DATABASE_URL=postgresql+asyncpg://calorietracker:secret@db:5432/calorietracker

# JWT signing secret — change to a long random string in production.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# ── Frontend ──────────────────────────────────────────────────────────────────
# The base URL the browser uses to reach the API.
VITE_API_URL=http://localhost:8000

# ── Misc ─────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
